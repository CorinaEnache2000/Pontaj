<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pontaj</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Pontaj.styles.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["HideNavbar"] is not true)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Pontaj</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Acasă</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Reports" asp-action="Index">Rapoarte</a>
                            </li>

                            @if (User.IsInRole("ADMINISTRATOR"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Administrare
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="OrganizationalUnits">Unități organizaționale</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Users">Utilizatori</a></li>
                                    </ul>
                                </li>
                            }
                        </ul>
                    </div>

                    <a class="nav-link text-dark disabled me-5">@User.FindFirst("DisplayName")?.Value</a>
                    <a id="btn-logout" class="nav-link text-danger fw-bolder" href="Account/Login">
                        Logout <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </nav>
        </header>
    }
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-2">
        <div class="container d-flex align-items-center justify-content-between">
            <span>&copy; @DateTime.Now.Year Clinica Sante &mdash; Pontaj</span>
            <img src="~/images/logo-sante.jpg" alt="Clinica Sante" style="height: 2.75rem;" />
        </div>
    </footer>
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="alert" role="alert" aria-live="assertive" aria-atomic="true" class="toast" data-bs-autohide="true">
            <div id="toastHeader" class="toast-header">
                <i class="bi bi-info-circle text-secondary"></i>&nbsp;
                <strong id="toastTitle" class="me-auto">Pontaj</strong>
                <small id="toastCreationMoment"></small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Închide"></button>
            </div>
            <iframe id="toastContentHTML" class="toast-body d-none" style="flex: 1; width: 100%; border: 0;"></iframe>
            <div id="toastContent" class="toast-body d-none" style="flex: 1; width: 100%; border: 0;"></div>
        </div>
    </div>

   @*  <script>
        function logoutFix(e) {
            localStorage.clear();
            sessionStorage.clear();
        }
    </script> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
